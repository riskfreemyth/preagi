---
const links = [
  {
    label: "Work",
    handle: "ramp.com",
    href: "https://ramp.com",
  },
  {
    label: "Mentor",
    handle: "buildafterdark.com",
    href: "https://buildafterdark.com",
  },
  {
    label: "Writing",
    handle: "@preagi",
    href: "https://substack.com/@preagi",
  },
  {
    label: "X / Twitter",
    handle: "@riskfreemyth",
    href: "https://twitter.com/riskfreemyth",
  },
  {
    label: "Cooking",
    handle: "@cooktochef",
    href: "https://instagram.com/cooktochef",
  },
  {
    label: "Cova (the Hovawart)",
    handle: "@covathehova",
    href: "https://instagram.com/covathehova",
  },
  {
    label: "Podcast",
    handle: "Unfriendly Banter",
    href: "https://www.youtube.com/@unfriendlybanter",
  },
  {
    label: "Email",
    handle: "hello@preagi.ai",
    href: "mailto:hello@preagi.ai",
  },
];
---

<section class="mb-8 sm:mb-10">
  <h2 class="mono text-sm uppercase tracking-[0.2em] accent mb-6">
    Where to find me
  </h2>
  <ul class="space-y-3">
    {links.map((l) => (
      <li class="flex items-baseline justify-between gap-4">
        <span class="muted">{l.label}</span>
        <a
          href={l.href}
          target={l.href.startsWith("mailto:") ? undefined : "_blank"}
          rel="noreferrer"
          class="mono text-sm"
        >
          {l.handle}
        </a>
      </li>
    ))}
  </ul>
</section>
