---

<section class="mb-8 sm:mb-10">
  <h2 class="mono text-sm uppercase tracking-[0.2em] accent mb-6">
    Where to find me
  </h2>

  <ul class="space-y-3">
    {
      primary.map((l) => (
        <li class="flex items-baseline justify-between gap-4">
          <span class="muted">{l.label}</span>
          <a
            href={l.href}
            target={l.href.startsWith("mailto:") ? undefined : "_blank"}
            rel="noreferrer"
            class="mono text-sm"
          >
            {l.handle}
          </a>
        </li>
      ))
    }
    <li class="flex items-center justify-between gap-4">
      <span class="muted">Contact socials</span>
      <div class="flex items-center gap-4">
        {
          icons.map((i) => (
            <a
              href={i.href}
              target="_blank"
              rel="noreferrer"
              aria-label={i.label}
              class="icon-link"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                width="20"
                height="20"
                aria-hidden="true"
              >
                <path d={i.path} />
              </svg>
            </a>
          ))
        }
      </div>
    </li>
  </ul>
</section>
