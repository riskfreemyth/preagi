---
const primary = [
  {
    label: "Work",
    handle: "ramp.com",
    href: "https://ramp.com",
  },
  {
    label: "Mentor",
    handle: "buildafterdark.com",
    href: "https://buildafterdark.com",
  },
  {
    label: "Writing",
    handle: "@preagi",
    href: "https://substack.com/@preagi",
  },
];

const elsewhere = [
  { handle: "@riskfreemyth", href: "https://twitter.com/riskfreemyth" },
  { handle: "@cooktochef", href: "https://instagram.com/cooktochef" },
  { handle: "@covathehova", href: "https://instagram.com/covathehova" },
  {
    handle: "Unfriendly Banter",
    href: "https://www.youtube.com/@unfriendlybanter",
  },
];
---

<section class="mb-8 sm:mb-10">
  <h2 class="mono text-sm uppercase tracking-[0.2em] accent mb-6">
    Where to find me
  </h2>

  <ul class="space-y-3">
    {
      primary.map((l) => (
        <li class="flex items-baseline justify-between gap-4">
          <span class="muted">{l.label}</span>
          <a
            href={l.href}
            target="_blank"
            rel="noreferrer"
            class="mono text-sm"
          >
            {l.handle}
          </a>
        </li>
      ))
    }
  </ul>

  <p class="mono text-sm muted mt-6 leading-relaxed">
    {
      elsewhere.map((l, i) => (
        <>
          {i > 0 && <span> · </span>}
          <a href={l.href} target="_blank" rel="noreferrer">
            {l.handle}
          </a>
        </>
      ))
    }
  </p>

  <p class="mono text-sm mt-3">
    <a href="mailto:hello@preagi.ai" rel="noreferrer">hello@preagi.ai</a>
  </p>
</section>
