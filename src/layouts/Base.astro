---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Avinash Gopinathan — preagi",
  description = "Avinash Gopinathan. Director of Underwriting Strategy at Ramp. Operator, builder, AI optimist.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:creator" content="@riskfreemyth" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <script>
      import { inject } from "@vercel/analytics";
      inject();
    </script>
  </head>
  <body>
    <main class="mx-auto max-w-2xl px-6 py-16 sm:py-24">
      <slot />
    </main>
  </body>
</html>
